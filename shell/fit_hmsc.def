Bootstrap: docker
From: rocker/r-ver:4.3.2

%post
    # Update package lists
    apt-get update
    
    # Install Python first (critical dependency)
    apt-get install -y \
        python3 \
        python3-pip \
        python3-venv \
        python3-dev \
        python3-setuptools \
        python3-wheel

    # Verify Python is installed before continuing
    which python3 || { echo "Python3 installation failed"; exit 1; }